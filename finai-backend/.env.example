# ============================================================
# FinAI — Variáveis de Ambiente (Template)
# Copie este arquivo para .env e preencha com seus valores
# NUNCA commit o arquivo .env real — ele está no .gitignore
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=seu_usuario_aqui
POSTGRES_PASSWORD=sua_senha_segura_aqui
POSTGRES_DB=finai

# --- IMAP (Gmail) ---
# Use uma Senha de Aplicativo (App Password), nunca a senha principal
# Veja: https://support.google.com/accounts/answer/185833
EMAIL_ACCOUNT=seu_email@gmail.com
EMAIL_APP_PASSWORD=sua_senha_de_aplicativo_aqui
